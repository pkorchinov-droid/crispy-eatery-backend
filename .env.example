# Doshii Sandbox Credentials
# Copy these from https://dashboard.sandbox.doshii.io/integrations/apps/2091
DOSHII_CLIENT_ID=your_client_id_here
DOSHII_CLIENT_SECRET=your_client_secret_here

# Doshii Environment
DOSHII_BASE_URL=https://sandbox.doshii.io

# Venue ID (from the sandbox venue you created)
DOSHII_VENUE_ID=9JBbxVzAA

# Server
PORT=3001

# Staff auth — required for /dashboard, /orders (GET/PATCH/DELETE), /customers.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Open the dashboard at /dashboard?token=YOUR_TOKEN
STAFF_TOKEN=

# Comma-separated list of allowed browser origins for CORS.
# Example: https://crispy-menu.netlify.app,https://eatery.crispycatering.com
# Leave empty to only allow same-origin (dashboard served from this server).
FRONTEND_ORIGIN=

# Set to "true" to permit DELETE /orders (still requires staff token AND X-Confirm-Wipe header).
ALLOW_DESTRUCTIVE=false

# Resend API key for emailing bills
RESEND_API_KEY=
